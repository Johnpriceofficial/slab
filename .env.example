# ── GradedCardValue.com environment ─────────────────────────
# Copy to .env.local and fill in. Never commit real values.

# Client (browser) — Supabase project that holds slabs / slab_comps / slab-images
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: show the test-only "Delete test record" (hard delete) UI. Hidden in
# production builds by default. The authoritative gate is the server-side flag
# public.slab_settings.allow_hard_delete — this only controls whether the button
# is rendered. Leave unset (or "false") for real inventory; archival is standard.
# VITE_ALLOW_SLAB_HARD_DELETE=false

# ── SERVER-ONLY (Supabase Edge Function secrets) ─────────────
# Set ONLY as edge-function secrets, never with a VITE_ prefix. The browser
# never sees these.
#   supabase secrets set PRICECHARTING_API_TOKEN="your-token"   # paid PriceCharting sub
#   supabase secrets set OPENAI_API_KEY="your-key"              # analyze-slab image analysis
#   supabase secrets set OPENAI_ANALYZE_MODEL="gpt-5.6-terra"   # optional model override
#   supabase secrets set OPENAI_SCAN_MODEL="gpt-5.6-terra"      # optional live-scanner model override
#   supabase secrets set ANALYZE_DAILY_LIMIT="200"              # optional daily cost cap (default 200)
#   supabase secrets set SCAN_DAILY_LIMIT="300"                 # hard per-user ceiling; plan default is 5/day
# eBay seller/reference integration (server-only; all are required to enable eBay):
#   EBAY_CLIENT_ID, EBAY_CLIENT_SECRET, EBAY_REDIRECT_URI, EBAY_RU_NAME,
#   EBAY_TOKEN_ENCRYPTION_KEY, EBAY_ENVIRONMENT
# PRICECHARTING_API_TOKEN=<edge-function secret only>
# OPENAI_API_KEY=<edge-function secret only>
