# ── SlabVault environment ────────────────────────────────────
# Copy to .env.local and fill in. Never commit real values.

# Client (browser) — Supabase project that holds slabs / slab_comps / slab-images
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── SERVER-ONLY (Supabase Edge Function secret) ──────────────
# Set ONLY as an edge-function secret, never with a VITE_ prefix:
#   supabase secrets set PRICECHARTING_API_TOKEN="your-token"
# The browser never sees this. Requires a paid PriceCharting subscription.
# PRICECHARTING_API_TOKEN=<edge-function secret only>
